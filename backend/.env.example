## Backend environment (example)
# Copy to backend/.env and fill values.

# MySQL connection (used when DATABASE_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Ayaan@2002
DB_NAME=leadAI

# OR provide full SQLAlchemy URL:
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/lead_magnet_ai

# JWT signing secret (required for /api/auth/*)
JWT_SECRET=change-me-to-a-long-random-string

# Optional
AGENCY_NAME=Your IT Agency

